{
  "name": "List Stripe Customers",
  "description": "Calls Stripe GET /v1/customers.",
  "meta": {
    "provider": "stripe",
    "operationId": "listCustomers",
    "method": "GET",
    "path": "/v1/customers"
  },
  "input": {
    "bearerToken": "Optional explicit Stripe secret key. Falls back to env.STRIPE_SECRET_KEY.",
    "limit": "Optional customer page size (1-100).",
    "startingAfter": "Optional pagination cursor."
  },
  "inputRequired": [],
  "ruleset": {
    "_pbd_nebula_type": "api_req",
    "host": {
      "_pbd_nebula_type": "condition",
      "op": "!=",
      "left": {
        "_pbd_nebula_type": "var",
        "keyPath": "env.STRIPE_API_BASE",
        "optional": true
      },
      "right": "",
      "then": {
        "_pbd_nebula_type": "var",
        "keyPath": "env.STRIPE_API_BASE",
        "optional": true
      },
      "else": "https://api.stripe.com"
    },
    "path": "/v1/customers",
    "query": {
      "limit": {
        "_pbd_nebula_type": "var",
        "keyPath": "limit",
        "optional": true
      },
      "starting_after": {
        "_pbd_nebula_type": "var",
        "keyPath": "startingAfter",
        "optional": true
      }
    },
    "method": "GET",
    "body": null,
    "headers": {
      "Authorization": {
        "_pbd_nebula_type": "subwork",
        "workflow": "stripe/getAuthHeader/v1",
        "payload": {
          "bearerToken": {
            "_pbd_nebula_type": "var",
            "keyPath": "bearerToken",
            "optional": true
          }
        }
      },
      "Content-Type": "application/x-www-form-urlencoded"
    }
  },
  "output": {
    "statusCode": 200,
    "body": {
      "data": []
    }
  }
}
