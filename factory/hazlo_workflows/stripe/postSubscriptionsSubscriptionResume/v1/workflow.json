{
  "name": "Resume a subscription",
  "description": "<p>Initiates resumption of a paused subscription, optionally resetting the billing cycle anchor and creating prorations. If no resumption invoice is generated, the subscription becomes <code>active</code> immediately. If a resumption invoice is generated, the subscription remains <code>paused</code> until the invoice is paid or marked uncollectible. If the invoice is not paid by the expiration date, it is voided and the subscription remains <code>paused</code>.</p>",
  "meta": {
    "method": "POST",
    "operationId": "postSubscriptionsSubscriptionResume",
    "path": "/v1/subscriptions/{subscription}/resume",
    "provider": "stripe"
  },
  "input": {
    "authBearerAuth": "<string>",
    "body": {
      "billing_cycle_anchor": "now",
      "expand": [
        "<string>"
      ],
      "proration_behavior": "always_invoice",
      "proration_date": "<number>"
    },
    "pathSubscription": "<string>"
  },
  "inputRequired": [
    "pathSubscription"
  ],
