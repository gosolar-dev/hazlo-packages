{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hazlo.dev/schema/release-manifest.schema.json",
  "title": "Hazlo Release Manifest",
  "description": "Manifest used by factory scripts to lint, smoke-evaluate, and publish package versions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "package",
    "version",
    "provider",
    "mode",
    "description",
    "defaultInstallRefs",
    "env",
    "homepage",
    "license",
    "tags",
    "smokeTests"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "package": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+$"
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "refs"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      },
      "uniqueItems": true
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "defaultInstallRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      },
      "uniqueItems": true
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "required",
          "description"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "homepage": {
      "type": "string",
      "minLength": 1,
      "format": "uri"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "smokeTests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ref",
          "input",
          "expected"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ref": {
            "$ref": "#/$defs/ref"
          },
          "input": {
            "type": "string",
            "minLength": 1
          },
          "expected": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "refs"
          }
        }
      },
      "then": {
        "required": [
          "refs"
        ],
        "properties": {
          "refs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "ref": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*/[A-Za-z0-9][A-Za-z0-9_-]*/v\\d+$"
    }
  }
}
